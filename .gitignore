## MY DATA FILES #############################################

# exclude Adobe files
*.indd
*.pdf
*.ai

# exclude bioinformatics output files
*.stats
*.lima.*
*.graph
*.mout
*.uc

# exclude Endnote library files
*.enlp
*.enlx

# exclude image files
*.png
*.jpg
*.svg
*.tif

# exclude JSON files
*.json
*.geojson

# exclude log / summary files
*.log
*.out
*.err

# exclude powerpoint files
*.pptx
*.potx

# exclude sequence files
*.bam*
*.fasta.gz
*.fastq.gz
*.fastq
*.fasta
*.fa
*.udb

# exclude zip archives (typically reference sequence db)
*.zip

# exclude tables
*.csv
*.xlsx

# exclude text files
*.doc
*.docx
*.tsv
*.txt

# exclude links to websites (e.g., Google Drive links)
*.webloc